{
  "name": "treasury-mcp-server",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "deploy": "wrangler deploy",
    "dev": "wrangler dev --port 8864",
    "start": "wrangler dev",
    "cf-typegen": "wrangler types",
    "lint": "biome lint --diagnostic-level=error src/",
    "type-check": "npm run cf-typegen && tsc --noEmit",
    "test:regression": "node test/structured-content-regression.mjs",
    "test": "npm run type-check && npm run test:regression"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.26.0",
    "@bio-mcp/shared": "workspace:*",
    "agents": "^0.7.6",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.1.3",
    "@types/node": "^24.2.1",
    "typescript": "5.8.3",
    "wrangler": "^4.56.0"
  },
  "overrides": {
    "@modelcontextprotocol/sdk": "1.26.0"
  },
  "workspaces": [
    "packages/*"
  ]
}
